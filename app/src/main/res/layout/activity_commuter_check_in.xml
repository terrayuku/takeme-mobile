<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding_horizontal">

    <!-- Status icon -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:contentDescription="Boarding check-in"
        android:src="@drawable/directions"
        android:tint="@color/colorPrimary" />

    <!-- Status message -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:text="Boarding window is open.\nTap Board to check in."
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.Takeme.Body"
        android:lineSpacingMultiplier="1.4" />

    <!-- Countdown card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="@dimen/spacing_xl"
        app:cardCornerRadius="70dp"
        app:cardElevation="@dimen/elevation_medium"
        app:strokeColor="@color/colorPrimary"
        app:strokeWidth="3dp">

        <TextView
            android:id="@+id/tv_boarding_countdown"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/colorPrimary"
            android:textSize="56sp"
            android:textStyle="bold" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:text="seconds remaining"
        android:textAppearance="@style/TextAppearance.Takeme.Caption" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:indeterminateTint="@color/colorPrimary"
        android:visibility="gone" />

    <!-- Board button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_board"
        style="@style/Widget.Takeme.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginBottom="@dimen/spacing_md"
        android:text="Board"
        app:icon="@drawable/done"
        app:iconGravity="textStart" />

    <!-- Scan QR fallback button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_scan_qr"
        style="@style/Widget.Takeme.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="Scan QR"
        app:icon="@drawable/camera"
        app:iconGravity="textStart" />

</LinearLayout>
